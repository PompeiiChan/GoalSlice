# 复制为 backend/.env 并填入真实 Key（勿提交 .env）
# 文档：https://docs.siliconflow.cn/cn/userguide/capabilities/text-generation
# API：https://api.siliconflow.cn/v1/chat/completions
# 鉴权：Authorization: Bearer <API_KEY>

LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen3.5-27B

# 双 Key：两节点共用一个主 Key，互为对方兜底 Key
LLM_API_KEY_A=<硅基流动 Key A>
LLM_API_KEY_B=<硅基流动 Key B>

# 四个 LLM 业务节点路由（值 A 或 B）
# | 节点           | API                          | 主 Key | 兜底 Key |
# |----------------|------------------------------|--------|----------|
# | 计划生成       | POST /quests/generate        | A      | B        |
# | 完成反馈       | POST /events/{id}/complete   | A      | B        |
# | 任务降级       | POST /events/{id}/downgrade  | B      | A        |
# | 周复盘         | POST /quests/{id}/review     | B      | A        |

LLM_NODE_QUEST_GENERATE_PRIMARY=A
LLM_NODE_QUEST_GENERATE_FALLBACK=B
LLM_NODE_EVENT_COMPLETE_PRIMARY=A
LLM_NODE_EVENT_COMPLETE_FALLBACK=B
LLM_NODE_EVENT_DOWNGRADE_PRIMARY=B
LLM_NODE_EVENT_DOWNGRADE_FALLBACK=A
LLM_NODE_QUEST_REVIEW_PRIMARY=B
LLM_NODE_QUEST_REVIEW_FALLBACK=A

APP_HOST=127.0.0.1
APP_PORT=8099
DATABASE_URL=sqlite+aiosqlite:///./data/goalslice.db
